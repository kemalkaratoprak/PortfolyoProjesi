@model List<PortfolyoProjesi.Models.Project>

@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="container mt-5">
    <!-- Üst Başlık ve Hızlı Aksiyonlar -->
    <div class="d-flex justify-content-between align-items-center mb-4 bg-dark p-4 rounded shadow-lg border border-secondary">
        <div>
            <h2 class="text-info fw-bold mb-0">🛠️ Proje Yönetim Paneli</h2>
            <p class="text-white-50 mb-0">Sitenizdeki projeleri buradan kontrol edebilirsiniz.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm fw-bold">← Siteye Dön</a>
            <a asp-controller="Home" asp-action="Create" class="btn btn-success btn-sm fw-bold">+ Yeni Proje Ekle</a>
            <a asp-controller="Admin" asp-action="Logout" class="btn btn-danger btn-sm fw-bold">Oturumu Kapat</a>
        </div>
    </div>

    <!-- 1. KISIM: Proje Tablosu -->
    <div class="table-responsive shadow-lg rounded border border-secondary mb-5">
        <table class="table table-dark table-hover align-middle mb-0">
            <thead class="table-secondary text-dark">
                <tr>
                    <th scope="col" style="width: 80px;">Görsel</th>
                    <th scope="col">Başlık</th>
                    <th scope="col">Açıklama Özeti</th>
                    <th scope="col" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var proje in Model)
                {
                    <tr>
                        <td>
                            <div class="rounded overflow-hidden shadow-sm border border-secondary">
                                <img src="@proje.ImageUrl" style="width: 60px; height: 60px; object-fit: cover;" alt="@proje.Title" />
                            </div>
                        </td>
                        <td>
                            <span class="fw-bold text-info">@proje.Title</span>
                        </td>
                        <td>
                            <p class="text-white-50 mb-0" style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @proje.Description
                            </p>
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm">
                                <a asp-controller="Home" asp-action="Edit" asp-route-id="@proje.Id" class="btn btn-sm btn-info fw-bold">
                                    ✏️ Düzenle
                                </a>
                                <a asp-controller="Home" asp-action="Delete" asp-route-id="@proje.Id" 
                                   class="btn btn-sm btn-danger fw-bold" 
                                   onclick="return confirm('@proje.Title projesini silmek istediğinize emin misiniz?')">
                                    🗑️ Sil
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <hr class="my-5 border-secondary" style="border-width: 3px; opacity: 0.5;" />

<!-- 2. KISIM: Gelen Mesajlar Bölümü -->
<div class="mt-5 mb-5">
    <h2 class="text-warning mb-4"><i class="fas fa-envelope"></i> 📩 Gelen İletişim Mesajları</h2>
    <div class="table-responsive shadow-lg rounded bg-white p-2">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 50px;">#</th>
                    <th>Tarih</th>
                    <th>Gönderen</th>
                    <th>Konu</th>
                    <th>Mesaj</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Messages != null)
                {
                    @foreach (var msg in (List<PortfolyoProjesi.Models.ContactMessage>)ViewBag.Messages)
                    {
                        <!-- Okunmamış mesajların arkasını hafif renkli yapalım -->
                        <tr class="@(msg.IsRead ? "" : "table-warning")">
                            <td class="fw-bold text-muted">@msg.Id</td>
                            <td style="font-size: 0.85rem;">@msg.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="@(msg.IsRead ? "text-dark" : "fw-bold text-primary")">@msg.Name</span>
                            </td>
                            <td>@msg.Subject</td>
                            <td class="text-muted" style="font-size: 0.9rem;">@msg.Message</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    @if (!msg.IsRead)
                                    {
                                        <a asp-action="MarkAsRead" asp-route-id="@msg.Id" class="btn btn-sm btn-outline-success" title="Okundu İşaretle">
                                            ✅
                                        </a>
                                    }
                                    <a asp-action="DeleteMessage" asp-route-id="@msg.Id" 
                                       class="btn btn-sm btn-outline-danger" 
                                       onclick="return confirm('Bu mesajı silmek istediğine emin misin?')" title="Mesajı Sil">
                                        🗑️
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* Admin paneli için sayfa arkası biraz daha koyu olsun */
    body {
        background-color: #1a1a1a;
        color: white;
    }
    .bg-white {
        background-color: #ffffff !important;
        color: #333 !important;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.05);
    }
</style>