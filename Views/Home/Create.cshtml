@model PortfolyoProjesi.Models.Project

@{
    ViewData["Title"] = "Yeni Proje Ekle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow-lg p-4 rounded bg-dark text-white border border-info">
            <h2 class="text-center mb-4 text-info fw-bold">🚀 Yeni Proje Ekle</h2>
            <form asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label class="control-label text-info fw-bold">GitHub Linki</label>
                    <input name="GithubUrl" class="form-control bg-dark text-white border-secondary" placeholder="https://github.com/kullanici/proje" />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label text-info fw-bold">Canlı Demo Linki</label>
                    <input name="LiveUrl" class="form-control bg-dark text-white border-secondary" placeholder="https://proje-demo.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-info">Proje Başlığı</label>
                    <input asp-for="Title" class="form-control bg-dark text-white border-secondary" placeholder="Örn: E-Ticaret Uygulaması" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-info">Açıklama</label>
                    <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="3" placeholder="Projenin teknik detayları..." required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-info">Görsel Linki (URL)</label>
                    <input asp-for="ImageUrl" class="form-control bg-dark text-white border-secondary" placeholder="https://..." required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-info btn-lg fw-bold shadow">Projeyi Kaydet</button>
                    <a asp-action="Index" class="btn btn-outline-light">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>