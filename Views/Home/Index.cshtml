@model List<PortfolyoProjesi.Models.Project>

@{
    ViewData["Title"] = "Yazılım Geliştirici Portfolyosu";
}

<!-- Hero Section -->
<header class="py-5 mb-5" style="background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%); border-radius: 20px; border: 1px solid #333;">
    <div class="container px-5">
        <div class="row gx-5 align-items-center justify-content-center">
            <div class="col-lg-8">
                <div class="my-5 text-center text-xl-start">
                    <h1 class="display-5 fw-bolder text-white mb-2">Geleceği Kodla İnşa Ediyorum</h1>
                    <p class="lead fw-normal text-white-50 mb-4">ASP.NET Core ve SQL Server ile modern, güvenli ve ölçeklenebilir çözümler.</p>
                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-xl-start">
                        <a class="btn btn-info btn-lg px-4 me-sm-3 fw-bold" href="#projects">Projelerimi Gör</a>
                        <a class="btn btn-outline-light btn-lg px-4" href="#contact">İletişim</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Hakkımda Bölümü -->
<section class="py-5 bg-dark" id="about">
    <div class="container px-5 my-5">
        <div class="row gx-5 align-items-center">
            <div class="col-lg-5 text-center mb-5 mb-lg-0">
                <div class="position-relative d-inline-block">
                    <img class="img-fluid rounded-circle shadow-lg border border-info p-2" src="~/img/profil.jpeg" alt="Kemal Karatoprak" style="width: 280px; height: 280px; object-fit: cover;" />
                    <div class="position-absolute bottom-0 end-0 bg-info text-dark p-2 rounded-circle shadow">
                        <span class="fw-bold">🚀👨‍💻</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <h2 class="fw-bolder text-info mb-3">Ben Kimim?</h2>
                <p class="lead fw-normal text-white mb-4">
                    Merhaba! Ben <strong>Kemal Karatoprak</strong>. Geleceği kodlarla inşa etmeye meraklı, ASP.NET Core ve modern web teknolojileri üzerine odaklanmış bir yazılım geliştiriciyim.
                </p>
                <p class="text-white-50 mb-4">
                    Karmaşık problemleri basit ve kullanıcı dostu çözümlere dönüştürmeyi seviyorum. Veri tabanı mimarileri, backend süreçleri ve şık kullanıcı arayüzleri oluşturmak benim için bir tutku.
                </p>
                <!-- CV İndirme ve İletişim Butonları -->
                <div class="d-flex gap-3 align-items-center">
                    <a href="#contact" class="btn btn-outline-info">Bana Ulaşın</a>
                    <a href="~/files/Kemal_Karatoprak_CV.pdf" download="Kemal_Karatoprak_CV.pdf" class="btn btn-link text-info text-decoration-none fw-bold">
                        <i class="bi bi-file-earmark-pdf-fill"></i> CV İndir (PDF)
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Teknik Yetkinlikler Bölümü -->
<section class="py-5 bg-dark border-bottom border-secondary mb-5">
    <div class="container px-5">
        <div class="text-center mb-5">
            <h2 class="fw-bolder text-info">Teknik Yetkinlikler</h2>
        </div>
        <div class="row gx-5">
            <div class="col-lg-6 mb-5">
                <div class="card h-100 bg-dark border-secondary shadow">
                    <div class="card-body p-4">
                        <h3 class="h5 text-info mb-4 border-bottom border-secondary pb-2"><i class="bi bi-code-slash me-2"></i>Diller</h3>
                        <p class="text-white-50">Python (İleri), C# (Orta), JavaScript, HTML5/CSS3</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="card h-100 bg-dark border-secondary shadow">
                    <div class="card-body p-4">
                        <h3 class="h5 text-info mb-4 border-bottom border-secondary pb-2"><i class="bi bi-stack me-2"></i>Teknolojiler</h3>
                        <p class="text-white-50">ASP.NET Core MVC, Entity Framework Core, SQL Server, Bootstrap</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Projeler Bölümü -->
<section id="projects" class="py-5 bg-dark">
    <div class="container px-4">
        <h2 class="fw-bolder mb-5 text-center text-info">Öne Çıkan Çalışmalarım</h2>
        <div class="row gx-4">
            @foreach (var proje in Model)
            {
                <div class="col-lg-4 mb-5">
                    <div class="card h-100 shadow-lg border-secondary bg-dark text-white">
                        <img class="card-img-top" src="@proje.ImageUrl" style="height: 200px; object-fit: cover;" />
                        <div class="card-body p-4">
                            <h5 class="card-title text-info">@proje.Title</h5>
                            <p class="text-white-50 small">@proje.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- İletişim Bölümü -->
<section class="py-5 bg-dark" id="contact">
    <div class="container px-5">
        <div class="bg-secondary rounded-4 py-5 px-4 px-md-5 shadow-lg border border-info">
            <div class="text-center mb-5">
                <h2 class="fw-bolder text-white">Bana Ulaşın</h2>
                @if (TempData["MessageSent"] != null)
                {
                    <div class="alert alert-success mt-3">@TempData["MessageSent"]</div>
                }
            </div>
            <div class="row gx-5 justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <form asp-action="SendMessage" asp-controller="Home" method="post">
                        <div class="form-floating mb-3">
                            <input class="form-control bg-dark text-white border-secondary" name="Name" id="name" type="text" placeholder="Ad Soyad" required />
                            <label for="name">Ad Soyad</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control bg-dark text-white border-secondary" name="Email" id="email" type="email" placeholder="E-posta" required />
                            <label for="email">E-posta</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control bg-dark text-white border-secondary" name="Subject" id="subject" type="text" placeholder="Konu" required />
                            <label for="subject">Konu</label>
                        </div>
                        <div class="form-floating mb-3">
                            <textarea class="form-control bg-dark text-white border-secondary" name="Message" id="message" style="height: 10rem" placeholder="Mesaj" required></textarea>
                            <label for="message">Mesaj</label>
                        </div>
                        <div class="d-grid"><button class="btn btn-info btn-lg fw-bold" type="submit">Gönder</button></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>