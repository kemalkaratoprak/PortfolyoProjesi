<!-- İletişim Bölümü -->
<section class="py-5 bg-dark" id="contact">
    <div class="container px-5">
        <div class="bg-secondary rounded-4 py-5 px-4 px-md-5 shadow-lg border border-info">
            <div class="text-center mb-5">
                <div class="feature bg-info bg-gradient text-dark rounded-3 mb-3 p-2 d-inline-block shadow">
                    <i class="bi bi-envelope"></i>
                </div>
                <h2 class="fw-bolder text-white">Bana Ulaşın</h2>
                <p class="lead fw-normal text-white-50 mb-0">Bir proje fikriniz mi var? Hadi konuşalım!</p>
                
                @if (TempData["MessageSent"] != null)
                {
                    <div class="alert alert-success mt-3">@TempData["MessageSent"]</div>
                }
            </div>
            <div class="row gx-5 justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <!-- Formun Backend Bağlantısı -->
                    <form asp-action="SendMessage" asp-controller="Home" method="post">
                        <div class="form-floating mb-3">
                            <input class="form-control bg-dark text-white border-secondary" name="Name" id="name" type="text" placeholder="Adınız..." required />
                            <label for="name" class="text-white-50">Ad Soyad</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control bg-dark text-white border-secondary" name="Email" id="email" type="email" placeholder="email@ornek.com" required />
                            <label for="email" class="text-white-50">E-posta Adresi</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control bg-dark text-white border-secondary" name="Subject" id="subject" type="text" placeholder="Konu" required />
                            <label for="subject" class="text-white-50">Konu</label>
                        </div>
                        <div class="form-floating mb-3">
                            <textarea class="form-control bg-dark text-white border-secondary" name="Message" id="message" style="height: 10rem" placeholder="Mesajınız..." required></textarea>
                            <label for="message" class="text-white-50">Mesajınız</label>
                        </div>
                        <div class="d-grid">
                            <button class="btn btn-info btn-lg fw-bold" type="submit">Gönder</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>